# Copy this file to docker/dev.env and fill in any secrets before running `docker compose up`.
JWT_SECRET=local-jwt-secret
FACTORY_API_KEY=dev-factory-key
DB_CONNECTION_SECRET=tempdbpassword
DB_NAME=pizza

# Grafana metrics (reuse the same values you used in .env for curl)
METRICS_ENDPOINT_URL=https://otlp-gateway-prod-us-east-3.grafana.net/otlp/v1/metrics
METRICS_ACCOUNT_ID=1567412
METRICS_API_KEY=glc_xxx
METRICS_SOURCE=jwt-pizza-service-dev
